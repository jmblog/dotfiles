{
  "env": {
    "DISABLE_MICROCOMPACT": "true",
    "ENABLE_TOOL_RESEARCH": "true"
  },
  "permissions": {
    "deny": [
      "Bash(*/python* *)",
      "Bash(python* *)",
      "Bash(*/node *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(*/bash *)",
      "Bash(sh *)",
      "Bash(*/sh *)",
      "Bash(zsh *)",
      "Bash(*/zsh *)",
      "Bash(csh *)",
      "Bash(*/csh *)",
      "Bash(tcsh *)",
      "Bash(*/tcsh *)",
      "Bash(ksh *)",
      "Bash(*/ksh *)",
      "Bash(fish *)",
      "Bash(*/fish *)",
      "Bash(dash *)",
      "Bash(*/dash *)",
      "Bash(go run *)",
      "Bash(*/go run *)",
      "Bash(curl *)",
      "Bash(*/curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(sed *)",
      "Bash(npx *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git -C *)",
      "Bash(chmod *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "mcp__claude_ai_Slack"
    ]
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py",
            "timeout": 86400
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(**)",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ $FILE == *.ts || $FILE == *.tsx ]]; then npx tsc --noEmit $FILE; fi"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/deny-check.sh"
          }
        ]
      },
      {
        "matcher": "Update(~/.claude/continuity/**)",
        "hooks": [
          {
            "type": "command",
            "command": "exit 0"
          }
        ]
      },
      {
        "matcher": "Write(~/.claude/continuity/**)",
        "hooks": [
          {
            "type": "command",
            "command": "exit 0"
          }
        ]
      },
      {
        "matcher": "Edit(~/.claude/continuity/**)",
        "hooks": [
          {
            "type": "command",
            "command": "exit 0"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          },
          {
            "type": "command",
            "command": "bash ~/.dotfiles/claude/scripts/sync-agent-skills.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-island-state.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline-command.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "code-analyzer@ubie-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "dig@kuu-marketplace": true,
    "git-workflow@ubie-plugins": true,
    "jmblog-plugins@jmblog-plugins": true,
    "mr@ubie-plugins": true,
    "swift-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "github.com",
        "api.github.com"
      ],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "//tmp/claude-work",
        "~/.npm",
        "~/.cache",
        "~/.agent-browser",
        "~/Library/Caches/go-build",
        "~/Library/Caches/ms-playwright"
      ],
      "denyWrite": [
        "//etc",
        "//usr",
        "//bin",
        "//sbin",
        "//opt",
        "//var",
        "//System",
        "//Library",
        "~/.ssh",
        "~/.gnupg",
        "~/.bashrc",
        "~/.bash_profile",
        "~/.zshrc",
        "~/.zprofile",
        "~/.profile",
        "~/.config/fish",
        "~/.claude/settings.json",
        "~/.claude/settings.local.json"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.docker/config.json",
        "~/.kube",
        "~/.npmrc",
        "~/.pypirc",
        "~/.netrc",
        "~/.git-credentials",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.gnome2/keyrings",
        "~/.kde/share/apps/kwallet",
        "~/.config/hub",
        "~/.config/op",
        "~/.config/configstore",
        "~/.terraform.d/credentials.tfrc.json",
        "~/.vault-token",
        "~/.config/sops",
        "~/.config/age",
        "~/.age",
        "~/.secrets",
        "~/.secrets.yaml",
        "~/.config/heroku",
        "~/.config/vercel",
        "~/.config/netlify",
        "~/.config/firebase",
        "~/.config/stripe",
        "~/.config/twilio",
        "~/.config/circleci",
        "~/.pulumi/credentials.json",
        "~/.sentryclirc",
        "~/.config/snyk",
        "~/.sup",
        "~/.config/helm",
        "~/.config/doctl",
        "~/.config/linode-cli",
        "~/.config/hcloud",
        "~/.fly",
        "~/.dbt/profiles.yml",
        "~/.pgpass",
        "~/.my.cnf",
        "~/.mongoshrc.js",
        "~/.rediscli_history",
        "~/.config/redis",
        "~/.claude/settings.json",
        "~/.claude/settings.local.json",
        "~/.bash_history",
        "~/.zsh_history",
        "~/.node_repl_history",
        "~/.python_history",
        "~/.psql_history",
        "~/.mysql_history",
        "~/.irb_history",
        "//etc/shadow",
        "//etc/gshadow",
        "//etc/sudoers",
        "//etc/ssl/private",
        "//etc/pki"
      ]
    },
    "excludedCommands": [
      "git:*",
      "gh:*",
      "gcloud:*",
      "docker:*",
      "bq:*"
    ]
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
